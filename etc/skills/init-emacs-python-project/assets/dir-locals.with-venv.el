;;; Directory Local Variables            -*- no-byte-compile: t -*-
;;; For more information see (info "(emacs) Directory Variables")

;; __VENV_ABS_PATH__ MUST be the absolute path to the project virtualenv and end with a trailing slash.
;; python-shell-interpreter stays as "python" because Emacs resolves it inside the venv.

((nil . ((python-shell-virtualenv-root . "__VENV_ABS_PATH__")
         (python-shell-interpreter . "python"))))
